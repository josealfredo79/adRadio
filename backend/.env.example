# IaRadio Backend — Environment Variables
# Copy this to .env and fill in your values

# App
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
FRONTEND_URL=https://app.iaradio.app

# Database (Neon PostgreSQL)
# Obtén la URL desde: Neon Console → Project → Connection Details → Connection string
# IMPORTANTE: usa el driver asyncpg y agrega ?ssl=require
# Formato directo:  postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/dbname?ssl=require
# Formato pooler:   postgresql+asyncpg://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?ssl=require
# (Usa el pooler en producción — puerto 6543, menor latencia en serverless)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-xxxxxx.us-east-2.aws.neon.tech/iaradio?ssl=require

# Redis (Railway)
REDIS_URL=redis://localhost:6379/0

# Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
# Números dedicados del pool para clientes Pro/Business (separados por coma)
# Deja vacío si solo usas el número compartido de arriba
TWILIO_NUMBER_POOL=

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OpenAI (Embeddings + Whisper)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Voyage AI (Embeddings RAG — https://www.voyageai.com)
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxx
# Delay entre llamadas de embedding (segundos). Free tier Voyage AI: ~3 RPM → 22s.
# Si tienes plan de pago, baja a 0 o 1.
VOYAGE_EMBEDDING_DELAY_S=22

# Google Cloud (Imagen 3)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}  # JSON string

# Google Calendar OAuth (for appointment sync)
GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=GOCSPX-your-client-secret

# Cloudflare R2
CF_R2_ACCESS_KEY=your-r2-access-key
CF_R2_SECRET_KEY=your-r2-secret-key
CF_R2_BUCKET=iaradio-files
CF_R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
CF_R2_PUBLIC_URL=https://files.iaradio.app

# Email (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=hola@iaradio.app

# Monitoring
SENTRY_DSN=https://xxxx@sentry.io/xxxxx
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxx
