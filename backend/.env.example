# =============================================================================
# IaRadio - Variables de Entorno
# Copia este archivo a .env y completa los valores
# =============================================================================

# ===== APP =====
DEBUG=true
APP_VERSION=2.0.0
API_PREFIX=/api/v1

# ===== DATABASE =====
# Neon PostgreSQL (ejemplo)
DATABASE_URL=postgresql+asyncpg://user:pass@host.neon.tech/dbname?ssl=require

# ===== REDIS =====
# Railway Redis (ejemplo)
REDIS_URL=redis://default:password@host.railway.internal:6379

# ===== JWT =====
SECRET_KEY=生成一个随机密钥: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
FROM_EMAIL=tu-email@gmail.com

# ===== TWILIO (WhatsApp) =====
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Pool de números propios (opcional)
# TWILIO_NUMBER_POOL=+525511111111,+525522222222

# ===== STRIPE (Pagos) =====
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== ANTHROPIC (Claude) =====
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== VOYAGE AI (Embeddings RAG) =====
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_EMBEDDING_DELAY_S=22

# ===== GOOGLE CLOUD (TTS + Imagen) =====
GOOGLE_CLOUD_PROJECT=tu-project-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----","client_email":"...@iam.gserviceaccount.com",...}

# Proveedor de TTS: "google", "fish", o "edge"
GOOGLE_TTS_PROVIDER=google
GOOGLE_TTS_VOICE_NAME=es-ES-Neural2-F

# ===== GOOGLE CALENDAR (Citas) =====
GOOGLE_CALENDAR_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=tu-client-secret

# ===== CLOUDFLARE R2 (Almacenamiento) =====
CF_R2_ACCESS_KEY=tu-access-key
CF_R2_SECRET_KEY=tu-secret-key
CF_R2_BUCKET=adradio-audio
CF_R2_ENDPOINT=https://tu-account.r2.cloudflarestorage.com
CF_R2_PUBLIC_URL=https://tu-account.r2.cloudflarestorage.com/adradio-audio

# ===== FISH AUDIO (TTS Alternativo) =====
FISH_AUDIO_API_KEY=tu-api-key
FISH_AUDIO_VOICE_ID=tu-voice-id

# ===== URLS =====
BASE_URL=https://tu-dominio.up.railway.app
FRONTEND_URL=http://localhost:5173

# ===== OPCIONALES =====
# SENTRY_DSN=tu-sentry-dsn
# POSTHOG_API_KEY=tu-posthog-key